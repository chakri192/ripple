# DataHub connection (local quickstart defaults shown)
DATAHUB_GMS_URL=http://localhost:8080
# Grab your token from ~/.datahubenv (the `token:` field) or DataHub UI → Settings → Access Tokens
DATAHUB_GMS_TOKEN=

# LLM for the narrative report. Guardian defaults to Anthropic; a Gemini path is stubbed in report.py.
ANTHROPIC_API_KEY=
